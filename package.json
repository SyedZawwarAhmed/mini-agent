{
  "name": "command-code-mini-agent",
  "version": "1.0.0",
  "description": "A TypeScript CLI mini-agent with Ink and local SKILL.md-based skills.",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mini-agent": "dist/index.js"
  },
  "files": [
    "dist",
    ".skills",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.0",
    "commander": "^14.0.1",
    "gray-matter": "^4.0.3",
    "ink": "^6.3.1",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
